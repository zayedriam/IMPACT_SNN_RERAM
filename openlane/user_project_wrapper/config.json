{
  "//": "Design files",
  "VERILOG_FILES": [
    "dir::../../verilog/rtl/defines.v",
    "dir::../../verilog/rtl/user_project_wrapper.v",
    "dir::../../verilog/rtl/nvm_core_decoder.v",
    "dir::../../verilog/rtl/nvm_neuron_block.v",
    "dir::../../verilog/rtl/nvm_neuron_core_256x64.v",
    "dir::../../verilog/rtl/nvm_neuron_spike_out.v",
    "dir::../../verilog/rtl/nvm_synapse_matrix.v"
  ],
  "EXTRA_VERILOG_MODELS": [
    "dir::../../ip/Neuromorphic_X1_32x32/hdl/NEUROMORPHIC_X1_stub.v"
  ],
  "MAGIC_EXT_USE_GDS": true,
  "MAGIC_EXT_ABSTRACT_CELLS": ["Neuromorphic_X1_wb"],
  "PNR_SDC_FILE": "dir::signoff.sdc",
  "SYNTH_ELABORATE_ONLY": false,
  "RUN_POST_GPL_DESIGN_REPAIR": true,
  "RUN_POST_CTS_RESIZER_TIMING": true,
  "DESIGN_REPAIR_BUFFER_INPUT_PORTS": true,

  "//": "SYNTHESIS - AREA strategy reduces buffer count and cell sizes",
   "SYNTH_STRATEGY": "AREA 0",
  "SYNTH_SIZING": true,
  "MAX_FANOUT_CONSTRAINT": 16,

  "//": "HOLD TIMING FIXES",
  "PL_RESIZER_HOLD_SLACK_MARGIN": 0.5,
  "GRT_RESIZER_HOLD_SLACK_MARGIN": 0.5,
  "PL_RESIZER_HOLD_MAX_BUFFER_PCT": 50,
  "GRT_RESIZER_HOLD_MAX_BUFFER_PCT": 70,

  "//": "SETUP TIMING - relaxed for congestion relief",
  "PL_RESIZER_SETUP_SLACK_MARGIN": 0.05,
  "GRT_RESIZER_SETUP_SLACK_MARGIN": 0.05,

  "//": "PLACEMENT SPREAD - FORCE cells to distribute across whole die, fix bottom-left clustering",
  "FP_CORE_UTIL": 10,
  "PL_TARGET_DENSITY_PCT": 20,
  "PL_WIRE_LENGTH_COEF": 0.05,

  "//": "PDN Configuration",
  "FP_PDN_CFG": "dir::pdn_override.tcl",
  "FP_PDN_ENABLE_RAILS": true,
  "PDN_CONNECT_MACROS_TO_GRID": true,

  "PDN_MACRO_CONNECTIONS": [
    "mprj.synapse_matrix_inst.X1_inst vccd1 vssd1 VDDC1 VSS",
    "mprj.synapse_matrix_inst.X1_inst vccd2 vssd1 VDDC2 VSS",
    "mprj.synapse_matrix_inst.X1_inst vdda1 vssd1 VDDA1 VSS",
    "mprj.synapse_matrix_inst.X1_inst vdda2 vssd1 VDDA2 VSS"
  ],

  "RUN_ANTENNA_REPAIR": true,
  "RUN_FILL_INSERTION": true,
  "RUN_TAP_ENDCAP_INSERTION": true,
  "FP_TAPCELL_DIST": 25,
  "RUN_CTS": true,
  "RUN_IRDROP_REPORT": false,
  "ERROR_ON_PDN_VIOLATIONS": false,
  "IGNORE_DISCONNECTED_MODULES": ["user_project_wrapper"],
  "VERILOG_POWER_DEFINE": "USE_POWER_PINS",
  "ERROR_ON_SYNTH_CHECKS": false,

  "MACROS": {
    "Neuromorphic_X1_wb": {
      "gds": ["dir::../../ip/Neuromorphic_X1_32x32/gds/Neuromorphic_X1_wb.gds"],
      "lef": ["dir::../../ip/Neuromorphic_X1_32x32/lef/Neuromorphic_X1_wb.lef"],
      "instances": {
        "mprj.synapse_matrix_inst.X1_inst": {
          "location": [600.0, 805.0],
          "orientation": "R0"
        }
      },
      "lib": { "*": "dir::../../ip/Neuromorphic_X1_32x32/lib/Neuromorphic_X1_wb.lib" }
    }
  },

  "MAGIC_DRC_USE_GDS": true,
  "MAGIC_CAPTURE_ERRORS": false,
  "ERROR_ON_MAGIC_DRC": false,
  "DRT_THREADS": 40,
  "MAX_TRANSITION_CONSTRAINT": 1.5,

  "//": "ANTENNA VIOLATION FIXES",
  "GRT_ANTENNA_ITERS": 20,
  "GRT_ANTENNA_MARGIN": 10,
  "RUN_HEURISTIC_DIODE_INSERTION": false,
  "DESIGN_REPAIR_MAX_WIRE_LENGTH": 1200,

  "//": "ROUTING - production mode with adjusted margin for tight channels",
  "GRT_ALLOW_CONGESTION": true,
  "GRT_OVERFLOW_ITERS": 250,
  "GRT_ADJUSTMENT": 0.1,

  "CLOCK_PERIOD": 100,
  "DESIGN_NAME": "user_project_wrapper",
  "FP_SIZING": "absolute",
  "DIE_AREA": [0, 0, 2920, 3520],
  "FP_DEF_TEMPLATE": "dir::fixed_dont_change/user_project_wrapper.def",
  "VDD_NETS": ["vccd1", "vdda1", "vccd2", "vdda2"],
  "GND_NETS": ["vssd1"],
  "CLOCK_PORT": "wb_clk_i",
  "SIGNOFF_SDC_FILE": "dir::signoff.sdc",
  "MAGIC_DEF_LABELS": true,
  "MAGIC_ZEROIZE_ORIGIN": false,
  "meta": { "version": 2 }
}